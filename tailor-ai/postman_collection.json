                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "string"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "me"
                            ]
                        },
                        "description": "Get authenticated user profile - Returns JSON. Requires JWT token."
                    },
                    "response": []
                },
                {
                    "name": "Request Password Reset",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "string"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"test@example.com\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/password-reset/request",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "password-reset",
                                "request"
                            ]
                        },
                        "description": "Request a password reset email. System will send a reset link to the email if the account exists. Returns success regardless to prevent email enumeration."
                    },
                    "response": []
                },
                {
                    "name": "Verify Reset OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "string"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"test@example.com\",\n    \"otp\": \"123456\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/password-reset/verify-otp",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "password-reset",
                                "verify-otp"
                            ]
                        },
                        "description": "Verify the 6-digit OTP sent to email. Returns valid: true if correct."
                    },
                    "response": []
                },
                {
                    "name": "Reset Password",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "string"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"test@example.com\",\n    \"otp\": \"123456\",\n    \"newPassword\": \"newPassword123\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/password-reset/reset",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "password-reset",
                                "reset"
                            ]
                        },
                        "description": "Reset password using the OTP code. Password must be at least 6 characters. OTP is invalidated after valid use."
                    },
                    "response": []
                }
            ]
        },
