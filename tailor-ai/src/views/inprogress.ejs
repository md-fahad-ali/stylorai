<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-bg: #102C4C;
            /* Dark Blue Sidebar */
            --accent-color: #E65F2A;
            /* Orange */
            --bg-color: #F8F9FA;
            --text-primary: #1A1A1A;
            --text-secondary: #666666;
            --border-color: #E0E0E0;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            background-color: var(--primary-bg);
            color: white;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .nav-menu {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 10px 16px;
            border-radius: 8px;
            color: #ccc;
            text-decoration: none;
            gap: 12px;
            transition: all 0.2s;
        }

        .nav-item:hover,
        .nav-item.active {
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
            font-weight: 500;
        }

        .nav-item.active {
            background-color: #E65F2A;
            /* Active Orange */
        }

        /* Main Content */
        .main-content {
            flex: 1;
            padding: 2rem 3rem;
            background: white;
            border-radius: 20px 0 0 20px;
            /* Optional rounded inner corner */
            margin-left: -5px;
            /* overlap slightly if needed */
        }

        .header-section {
            margin-bottom: 2rem;
        }

        h1.page-title {
            font-size: 1.5rem;
            color: var(--accent-color);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        p.page-subtitle {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        /* Filter & Search Bar */
        .controls-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .search-container {
            display: flex;
            align-items: center;
            background: #F5F5F5;
            padding: 4px 4px 4px 16px;
            border-radius: 50px;
            flex: 1;
            max-width: 400px;
        }

        .search-input {
            border: none;
            background: transparent;
            outline: none;
            flex: 1;
            font-size: 0.9rem;
            color: var(--text-primary);
        }

        .btn-search {
            background: var(--accent-color);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .filters {
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }

        .filter-pill {
            padding: 6px 16px;
            border-radius: 50px;
            border: 1px solid var(--border-color);
            background: white;
            color: var(--text-secondary);
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .filter-pill.active {
            background: #FDE8E1;
            /* Light Orange */
            color: var(--accent-color);
            border-color: #FDE8E1;
        }

        .btn-start-new {
            background: var(--accent-color);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            cursor: pointer;
        }

        /* Grid */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(450px, 1fr));
            gap: 1.5rem;
        }

        /* Card Design */
        .project-card {
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1rem;
            display: flex;
            gap: 1rem;
            background: white;
            position: relative;
        }

        .card-thumbnail {
            width: 120px;
            height: 100px;
            border-radius: 8px;
            object-fit: cover;
            background-color: #eee;
        }

        .card-details {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .project-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 2px;
        }

        .project-location {
            font-size: 0.8rem;
            color: var(--text-secondary);
        }

        .menu-dots {
            cursor: pointer;
            color: var(--text-secondary);
            font-size: 1.2rem;
            position: absolute;
            top: 10px;
            right: 16px;
        }

        /* Progress Bar */
        .progress-container {
            margin: 0.5rem 0;
        }

        .progress-track {
            background-color: #eee;
            height: 4px;
            border-radius: 2px;
            width: 100%;
            position: relative;
        }

        .progress-fill {
            background-color: var(--accent-color);
            height: 100%;
            border-radius: 2px;
            width: 70%;
            /* Dynamic */
        }

        .progress-marker {
            position: absolute;
            right: 0;
            top: 50%;
            transform: translate(50%, -50%);
            width: 8px;
            height: 8px;
            background: white;
            border: 2px solid var(--accent-color);
            border-radius: 50%;
        }

        .progress-text {
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
            margin-top: 6px;
            color: var(--accent-color);
            font-weight: 600;
        }

        .time-remaining {
            color: var(--text-secondary);
            font-weight: 400;
        }

        .status-text {
            font-size: 0.7rem;
            color: #F8B042;
            /* Loading text color */
            font-style: italic;
        }

        .start-date {
            font-size: 0.7rem;
            color: var(--text-secondary);
            margin-top: 4px;
        }

        .view-more-link {
            text-align: right;
            display: block;
            margin-top: 1rem;
            color: #102C4C;
            text-decoration: underline;
            font-size: 0.8rem;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="sidebar">
        <!-- Logo Text -->
        <h2 style="font-size: 1.2rem; font-weight: 700;">PropDNA</h2>

        <ul class="nav-menu">
            <li><a href="/" class="nav-item">🏠 Home</a></li>
            <li><a href="#" class="nav-item">📤 Uploads</a></li>
            <li><a href="#" class="nav-item">📂 Slide Decks</a></li>
            <li><a href="#" class="nav-item">📝 Draft</a></li>
            <li><a href="/dashboard/in-progress" class="nav-item active">⏳ In Progress</a></li>
            <li><a href="#" class="nav-item">✨ Suggestions</a></li>
        </ul>

        <div style="margin-top: auto;">
            <a href="#" class="nav-item">⚙️ Settings</a>
            <a href="#" class="nav-item">❓ Help & Support</a>
            <a href="/auth/logout" class="nav-item">🚪 Logout</a>
        </div>
    </div>

    <main class="main-content">
        <div class="header-section">
            <h1 class="page-title">Projects In Progress</h1>
            <p class="page-subtitle">Your AI-Powered Decks Are Being Generated, You'll Be Notified Once They're Ready.
            </p>
        </div>

        <div class="controls-bar">
            <!-- Search -->
            <div class="search-container">
                <span style="color: #999; margin-right: 8px;">🔍</span>
                <input type="text" class="search-input" placeholder="Search for recent drafts...">
                <button class="btn-search">Search</button>
            </div>

            <!-- Filters -->
            <div class="filters">
                <button class="filter-pill active">All</button>
                <button class="filter-pill">Analyzing data</button>
                <button class="filter-pill">Generating layout</button>
                <button class="filter-pill">Rendering slides</button>
                <button class="filter-pill">Almost ready</button>
            </div>

            <button class="btn-start-new">➕ Start Now</button>
        </div>

        <div class="projects-grid">
            <% projects.forEach(project=> { %>
                <div class="project-card">
                    <div class="menu-dots">⋮</div>
                    <img src="<%= project.image %>" alt="Thumbnail" class="card-thumbnail">

                    <div class="card-details">
                        <div>
                            <div class="card-header">
                                <div>
                                    <h3 class="project-title">
                                        <%= project.title %>
                                    </h3>
                                    <div class="project-location">
                                        <%= project.location %>
                                    </div>
                                </div>
                            </div>

                            <div class="progress-container">
                                <div class="progress-track">
                                    <div class="progress-fill" style="width: <%= project.progress %>%;">
                                        <div class="progress-marker"></div>
                                    </div>
                                </div>
                                <div class="progress-text">
                                    <span>
                                        <%= project.progress %>% Completed
                                    </span>
                                    <span class="time-remaining">
                                        <%= project.timeLeft %>
                                    </span>
                                </div>
                            </div>

                            <div class="status-text">
                                <%= project.status %>
                            </div>
                        </div>

                        <div class="start-date">Started on: <%= project.startDate %>
                        </div>
                    </div>
                </div>
                <% }); %>
        </div>

        <a href="#" class="view-more-link">View More</a>
    </main>

</body>

</html>